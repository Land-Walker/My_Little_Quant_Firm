    "\n",
    "ax.set_title(f'Forecast vs. Ground Truth (Sample {SAMPLE_IDX})', fontsize=16)\n",
    "ax.set_xlabel('Time Steps (from forecast point)')\n",
    "ax.set_ylabel('Denoised Price (Inverse Transformed)')\n",
    "ax.legend()\n",
    "ax.axvline(0, color='r', linestyle='--', lw=1, label='Forecast Start')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Save the plot\n",
    "os.makedirs(PLOT_OUTPUT_DIR, exist_ok=True)\n",
